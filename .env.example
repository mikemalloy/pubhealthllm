# pubHealthLLM — Environment Variables
# Copy this file to .env and fill in your API keys.
#
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.
# On HuggingFace Spaces, set these as Secrets in the Space settings
# (Settings → Variables and secrets → New secret).

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Anthropic API key — get one at https://console.anthropic.com
# Used for Claude Sonnet inference via PydanticAI
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# Optional overrides (defaults work fine for most setups)
# ---------------------------------------------------------------------------

# Override the Anthropic model (default: claude-sonnet-4-5)
# HEALTHGPT_MODEL=claude-sonnet-4-5

# Override ChromaDB path (default: data/chroma_db)
# CHROMA_DB_PATH=data/chroma_db

# Override SQLite path (default: data/healthgpt.db)
# SQLITE_DB_PATH=data/healthgpt.db
