# pubHealthLLM frontend — environment variable template
# Copy to .env.local and fill in real values. Never commit .env.local.
#
# Use the SAME Clerk instance as the backend (CLERK_JWKS_URL must share the same app).

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
CLERK_SECRET_KEY=sk_test_your-secret-key-here
NEXT_PUBLIC_API_URL=https://your-function-url.lambda-url.us-west-1.on.aws  # Backend API (AWS Lambda Function URL)
