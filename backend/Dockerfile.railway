# backend/Dockerfile.railway
# Railway deployment: build context is backend/ directory.
# Do NOT use for AWS — use backend/Dockerfile (project-root context) for that.
#
# Key properties:
#   - data/ is BAKED IN (healthgpt.db + chroma_db) — zero cold-start download.
#   - all-MiniLM-L6-v2 is PRE-DOWNLOADED at build time so startup validation
#     (check_vector_store) works fully offline at boot.
#   - $PORT is respected at runtime (Railway injects it; default 8000 locally).
#   - NOTE: bump memory to 2-4 GB in Railway settings — sentence-transformers
#     + ChromaDB need headroom.

FROM python:3.11-slim

WORKDIR /app

# System deps for sentence-transformers / chromadb
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies (split layer for better caching)
COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir \
    --extra-index-url https://download.pytorch.org/whl/cpu \
    -r /tmp/requirements.txt

# Pre-download the sentence-transformer embedding model used by ChromaDB/MMWR.
# Baking it into an image layer means the B5/PD1 startup check (check_vector_store)
# can load the Chroma collection fully offline at container boot — no runtime download.
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('all-MiniLM-L6-v2')"

# Bake application source
COPY server.py /app/

# Bake engine package
COPY pubhealth_llm/ /app/pubhealth_llm/

# Bake data artifacts (healthgpt.db ~69MB, chroma_db ~3MB, mmwr_pdfs ~3.5MB)
# Built during ingestion, committed via Git LFS.
# If data grows beyond ~500MB consider a Railway volume mount instead.
COPY data/ /app/data/

EXPOSE 8000

# $PORT is injected by Railway at runtime; default to 8000 for local docker run.
CMD ["sh", "-c", "uvicorn server:app --host 0.0.0.0 --port ${PORT:-8000} --workers 1"]
