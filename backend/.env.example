# pubHealthLLM backend — environment variable template
# Copy to .env and fill in real values. Never commit .env.
#
# The backend talks to live AWS resources (there is no local database), so it
# also needs AWS credentials (env vars, profile, or IAM role) with access to
# Bedrock, the RDS Data API, S3 Vectors, and SageMaker in AWS_REGION.

# --- Required: AWS data layer -------------------------------------------------
AWS_REGION=us-west-1

# Aurora Serverless v2 via RDS Data API (terraform/5_database outputs)
AURORA_CLUSTER_ARN=arn:aws:rds:us-west-1:123456789012:cluster:your-cluster
AURORA_SECRET_ARN=arn:aws:secretsmanager:us-west-1:123456789012:secret:your-secret
AURORA_DATABASE=pubhealth

# S3 Vectors — MMWR semantic search index (terraform/3_ingestion outputs)
VECTOR_BUCKET=your-vector-bucket-name
INDEX_NAME=mmwr-reports

# SageMaker real-time endpoint for query embeddings (terraform/2_sagemaker outputs)
SAGEMAKER_ENDPOINT=pubhealth-embedding-endpoint

# --- Required: Clerk authentication -------------------------------------------
# JWKS URL of the SAME Clerk instance the frontend uses.
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json

# --- Optional: model selection --------------------------------------------------
# Defaults to Bedrock Nova Pro (IAM auth — no API key needed).
# PUBHEALTH_MODEL=bedrock:us.amazon.nova-pro-v1:0
# Max model round-trips per agent run before fail-fast + auto-retry (default 12).
# PUBHEALTH_REQUEST_LIMIT=12

# Fallback providers — only needed if PUBHEALTH_MODEL uses them.
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-openai-key-here

# --- Optional: deploy / tooling -------------------------------------------------
# Extra CORS origins, comma-separated (localhost:3000/5173 always allowed).
# CORS_ORIGINS=https://pubhealth.chefmike.dev
# LlamaParse PDF extraction in the ingestion pipeline (falls back to PyPDF2).
# LLAMA_CLOUD_API_KEY=llx-your-llama-cloud-key-here
# Groq — used only by the decision_tree module (roadmap, not on the request path).
# GROQ_API_KEY=gsk_your-groq-key-here
